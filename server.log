1;\\n101\\t    }\\n102\\t    const voteDiff = (b.voteCount ?? 0) - (a.voteCount ?? 0);\\n103\\t    if (voteDiff !== 0) return voteDiff;\\n104\\t    return new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime();\\n105\\t  });\\n106\\t  return sorted;\\n107\\t};\\n108\\t\\n109\\tconst logFirestoreError = (error: unknown, context: string) => {\\n110\\t  console.error(`[Firestore:${context}]`, error);\\n111\\t  if (error && typeof error === \\'object\\' && \\'message\\' in error) {\\n112\\t    console.error(`[Firestore:${context}] message:`, (error as { message: string }).message);\\n113\\t  }\\n114\\t  if (error && typeof error === \\'object\\' && \\'code\\' in error) {\\n115\\t    console.error(`[Firestore:${context}] code:`, (error as { code: string }).code);\\n116\\t  }\\n117\\t};\\n118\\t\\n119\\ttype MinimalUserProfile = {\\n120\\t  name: string;\\n121\\t  avatarUrl: string | null | undefined;\\n122\\t};\\n123\\t\\n124\\tconst defaultUserProfile: MinimalUserProfile = {\\n125\\t  name: \\'Ng\u01b0\u1eddi d\u00f9ng\\',\\n126\\t  avatarUrl: null,\\n127\\t};\\n128\\t\\n129\\tconst userProfileCache = new Map<string, MinimalUserProfile>();\\n130\\t\\n131\\tconst fetchUserProfile = async (userId: string): Promise<MinimalUserProfile> => {\\n132\\t  try {\\n133\\t    const snap = await getDoc(doc(db, \\'users\\', userId));\\n134\\t    if (snap.exists()) {\\n135\\t      const data = snap.data() ?? {};\\n136\\t      const profile: MinimalUserProfile = {\\n137\\t        name: data.name ?? defaultUserProfile.name,\\n138\\t        avatarUrl: data.avatarUrl ?? data.photoURL ?? defaultUserProfile.avatarUrl,\\n139\\t      };\\n140\\t      userProfileCache.set(userId, profile);\\n141\\t      return profile;\\n142\\t    }\\n143\\t  } catch (error) {\\n144\\t    logFirestoreError(error, `fetchUserProfile(${userId})`);\\n145\\t  }\\n146\\t  const fallbackProfile: MinimalUserProfile = { ...defaultUserProfile };\\n147\\t  userProfileCache.set(userId, fallbackProfile);\\n148\\t  return fallbackProfile;\\n149\\t};\\n150\\t\\n151\\tconst getUserProfile = async (\\n152\\t  userId?: string | null,\\n153\\t  fallbackName?: string,\\n154\\t  fallbackAvatar?: string | null\\n155\\t): Promise<MinimalUserProfile> => {\\n156\\t  if (!userId) {\\n157\\t    return {\\n158\\t      name: fallbackName ?? defaultUserProfile.name,\\n159\\t      avatarUrl: fallbackAvatar ?? defaultUserProfile.avatarUrl,\\n160\\t    };\\n161\\t  }\\n162\\t  if (userProfileCache.has(userId)) {\\n163\\t    const cached = userProfileCache.get(userId)!;\\n164\\t    return {\\n165\\t      name: cached.name ?? fallbackName ?? defaultUserProfile.name,\\n166\\t      avatarUrl: cached.avatarUrl ?? fallbackAvatar ?? defaultUserProfile.avatarUrl,\\n167\\t    };\\n168\\t  }\\n169\\t  const profile = await fetchUserProfile(userId);\\n170\\t  return {\\n171\\t    name: profile.name ?? fallbackName ?? defaultUserProfile.name,\\n172\\t    avatarUrl: profile.avatarUrl ?? fallbackAvatar ?? defaultUserProfile.avatarUrl,\\n173\\t  };\\n174\\t};\\n175\\t\\n176\\ttype EntityWithUser = { user: Comment[\\'user\\']; authorId?: string };\\n177\\t\\n178\\tconst hydrateEntityUser = async <T extends EntityWithUser>(entity: T): Promise<T> => {\\n179\\t  const profile = await getUserProfile(entity.authorId ?? entity.user.id, entity.user.name, entity.user.avatarUrl ?? null);\\n180\\t  return {\\n181\\t    ...entity,\\n182\\t    user: {\\n183\\t      ...entity.user,\\n184\\t      name: profile.name,\\n185\\t      avatarUrl: profile.avatarUrl ?? undefined,\\n186\\t    },\\n187\\t  };\\n188\\t};\\n189\\t\\n190\\tconst hydratePostsUsers = async (posts: Post[]): Promise<Post[]> =>\\n191\\t  Promise.all(posts.map((post) => hydrateEntityUser(post)));\\n192\\t\\n193\\tconst hydrateCommentsUsers = async (comments: Comment[]): Promise<Comment[]> =>\\n194\\t  Promise.all(comments.map((comment) => hydrateEntityUser(comment)));\\n195\\t\\n196\\t/**\\n197\\t * Realtime danh s\u00e1ch b\u00e0i \u0111\u0103ng (sorted by createdAt desc)\\n198\\t */\\n199\\texport const subscribeToCommunityPosts = (\\n200\\t  callback: (posts: Post[]) => void\\n201\\t): (() => void) => {\\n202\\t  const currentUser = auth.currentUser;\\n203\\t  const postsQuery = query(collection(db, \\'posts\\'), orderBy(\\'createdAt\\', \\'desc\\'));\\n204\\t\\n205\\t  const unsubscribe = onSnapshot(postsQuery, async (snapshot) => {\\n206\\t    const rawPosts = snapshot.docs.map((docSnap) => mapPost(docSnap.id, docSnap.data()));\\n207\\t    const hydratedPosts = await hydratePostsUsers(rawPosts);\\n208\\t\\n209\\t    if (!currentUser) {\\n210\\t      callback(hydratedPosts);\\n211\\t      return;\\n212\\t    }\\n213\\t\\n214\\t    const postsWithVote = await Promise.all(\\n215\\t      hydratedPosts.map((post) => attachUserVote(post, currentUser.uid))\\n216\\t    );\\n217\\t    callback(postsWithVote);\\n218\\t  }, (error) => {\\n219\\t    logFirestoreError(error, \\'subscribeToCommunityPosts\\');\\n220\\t  });\\n221\\t\\n222\\t  return unsubscribe;\\n223\\t};\\n224\\t\\n225\\t/**\\n226\\t * Fetch danh s\u00e1ch b\u00e0i \u0111\u0103ng m\u1ed9t l\u1ea7n\\n227\\t */\\n228\\texport const getCommunityPosts = async (): Promise<Post[]> => {\\n229\\t  try {\\n230\\t    const snapshot = await getDocs(query(collection(db, \\'posts\\'), orderBy(\\'createdAt\\', \\'desc\\')));\\n231\\t    const currentUser = auth.currentUser;\\n232\\t    const posts = snapshot.docs.map((docSnap) => mapPost(docSnap.id, docSnap.data()));\\n233\\t    const hydratedPosts = await hydratePostsUsers(posts);\\n234\\t\\n235\\t    if (!currentUser) {\\n236\\t      return hydratedPosts;\\n237\\t    }\\n238\\t\\n239\\t    return await Promise.all(hydratedPosts.map((post) => attachUserVote(post, currentUser.uid)));\\n240\\t  } catch (error) {\\n241\\t    logFirestoreError(error, \\'getCommunityPosts\\');\\n242\\t    throw error;\\n243\\t  }\\n244\\t};\\n245\\t\\n246\\t/**\\n247\\t * Fetch chi ti\u1ebft b\u00e0i \u0111\u0103ng m\u1ed9t l\u1ea7n\\n248\\t */\\n249\\texport const getPostById = async (id: string): Promise<Post | null> => {\\n250\\t  try {\\n251\\t    const snap = await getDoc(doc(db, \\'posts\\', id));\\n252\\t    if (!snap.exists()) return null;\\n253\\t    const post = await hydrateEntityUser(mapPost(snap.id, snap.data()));\\n254\\t    const currentUser = auth.currentUser;\\n255\\t    if (!currentUser) return post;\\n256\\t    return await attachUserVote(post, currentUser.uid);\\n257\\t  } catch (error) {\\n258\\t    logFirestoreError(error, `getPostById(${id})`);\\n259\\t    throw error;\\n260\\t  }\\n261\\t};\\n262\\t\\n263\\t/**\\n264\\t * Fetch b\u00e0i \u0111\u0103ng theo lo\u1ea1i c\u00e2y tr\u1ed3ng\\n265\\t */\\n266\\texport const getPostsByCropType = async (cropType: string): Promise<Post[]> => {\\n267\\t  try {\\n268\\t    const postsQuery = query(\\n269\\t      collection(db, \\'posts\\'),\\n270\\t      where(\\'cropType\\', \\'==\\', cropType),\\n271\\t      orderBy(\\'createdAt\\', \\'desc\\')\\n272\\t    );\\n273\\t    const snapshot = await getDocs(postsQuery);\\n274\\t    const currentUser = auth.currentUser;\\n275\\t    const posts = snapshot.docs.map((docSnap) => mapPost(docSnap.id, docSnap.data()));\\n276\\t    const hydratedPosts = await hydratePostsUsers(posts);\\n277\\t\\n278\\t    if (!currentUser) {\\n279\\t      return hydratedPosts;\\n280\\t    }\\n281\\t\\n282\\t    return await Promise.all(hydratedPosts.map((post) => attachUserVote(post, currentUser.uid)));\\n283\\t  } catch (error) {\\n284\\t    logFirestoreError(error, `getPostsByCropType(${cropType})`);\\n285\\t    throw error;\\n286\\t  }\\n287\\t};\\n288\\t\\n289\\t/**\\n290\\t * T\u1ea1o b\u00e0i \u0111\u0103ng m\u1edbi\\n291\\t */\\n292\\texport const createPost = async (postData: CreatePostRequest): Promise<Post | null> => {\\n293\\t  const user = auth.currentUser;\\n294\\t  if (!user) throw new Error(\\'Not authenticated\\');\\n295\\t\\n296\\t  try {\\n297\\t    // Upload \u1ea3nh l\u00ean Cloudinary n\u1ebfu c\u00f3\\n298\\t    let cloudinaryImageUrl: string | null = null;\\n299\\t    let cloudinaryImageUrls: string[] | null = null;\\n300\\t\\n301\\t    if (postData.imageUrl) {\\n302\\t      console.log(\\'\ud83d\udce4 \u0110ang upload \u1ea3nh \u0111\u01a1n l\u00ean Cloudinary...\\');\\n303\\t      const result = await uploadImageToCloudinary(postData.imageUrl, \\'cropwise/community\\');\\n304\\t      if (result.success && result.url) {\\n305\\t        cloudinaryImageUrl = result.url;\\n306\\t        console.log(\\'\u2705 Upload \u1ea3nh th\u00e0nh c\u00f4ng:\\', cloudinaryImageUrl);\\n307\\t      } else {\\n308\\t        console.error(\\'\u274c Upload \u1ea3nh th\u1ea5t b\u1ea1i:\\', result.error);\\n309\\t        throw new Error(\\'Kh\u00f4ng th\u1ec3 upload \u1ea3nh. Vui l\u00f2ng th\u1eed l\u1ea1i.\\');\\n310\\t      }\\n311\\t    }\\n312\\t\\n313\\t    if (postData.imageUrls && postData.imageUrls.length > 0) {\\n314\\t      console.log(\\'\ud83d\udce4 \u0110ang upload nhi\u1ec1u \u1ea3nh l\u00ean Cloudinary...\\');\\n315\\t      cloudinaryImageUrls = await uploadMultipleImages(postData.imageUrls, \\'cropwise/community\\');\\n316\\t      if (cloudinaryImageUrls.length === 0) {\\n317\\t        throw new Error(\\'Kh\u00f4ng th\u1ec3 upload \u1ea3nh. Vui l\u00f2ng th\u1eed l\u1ea1i.\\');\\n318\\t      }\\n319\\t      console.log(`\u2705 Upload ${cloudinaryImageUrls.length} \u1ea3nh th\u00e0nh c\u00f4ng`);\\n320\\t    }\\n321\\t\\n322\\t    const postRef = await addDoc(collection(db, \\'posts\\'), {\\n323\\t      authorId: user.uid,\\n324\\t      authorName: user.displayName ?? null,\\n325\\t      authorAvatarUrl: user.photoURL ?? null,\\n326\\t      title: postData.title ?? null,\\n327\\t      content: postData.content,\\n328\\t      description: postData.description ?? null,\\n329\\t      imageUrl: cloudinaryImageUrl,\\n330\\t      imageUrls: cloudinaryImageUrls,\\n331\\t      cropType: postData.cropType ?? null,\\n332\\t      tags: postData.tags ?? null,\\n333\\t      likeCount: 0,\\n334\\t      dislikeCount: 0,\\n335\\t      voteCount: 0,\\n336\\t      commentCount: 0,\\n337\\t      bestAnswerId: null,\\n338\\t      createdAt: serverTimestamp(),\\n339\\t    });\\n340\\t\\n341\\t    const snap = await getDoc(postRef);\\n342\\t    if (!snap.exists()) return null;\\n343\\t    const hydratedPost = await hydrateEntityUser(mapPost(snap.id, snap.data()));\\n344\\t    return applyUserVoteToPost(hydratedPost, 0);\\n345\\t  } catch (error) {\\n346\\t    logFirestoreError(error, \\'createPost\\');\\n347\\t    throw error;\\n348\\t  }\\n349\\t};\\n350\\t\\n351\\t/**\\n352\\t * Transaction x\u1eed l\u00fd like/dislike b\u00e0i \u0111\u0103ng\\n353\\t */\\n354\\texport const likePost = async (likeData: LikePostRequest): Promise<Post | null> => {\\n355\\t  const user = auth.currentUser;\\n356\\t  if (!user) throw new Error(\\'Not authenticated\\');\\n357\\t\\n358\\t  const postRef = doc(db, \\'posts\\', likeData.postId);\\n359\\t  const voteRef = doc(db, \\'posts\\', likeData.postId, \\'votes\\', user.uid);\\n360\\t  const nextValue = resolveVoteValue(likeData.action);\\n361\\t\\n362\\t  try {\\n363\\t    let postAuthorId: string | null = null;\\n364\\t    let postTitle: string | null = null;\\n365\\t    let shouldNotify = false;\\n366\\t\\n367\\t    await runTransaction(db, async (tx: Transaction) => {\\n368\\t      const postSnap = await tx.get(postRef);\\n369\\t      if (!postSnap.exists()) throw new Error(\\'Post not found\\');\\n370\\t\\n371\\t      const voteSnap = await tx.get(voteRef);\\n372\\t      const prevValue = voteSnap.exists() ? ((voteSnap.data().value as number) ?? 0) : 0;\\n373\\t\\n374\\t      if (prevValue === nextValue) {\\n375\\t        return;\\n376\\t      }\\n377\\t\\n378\\t      const data = postSnap.data() ?? {};\\n379\\t      postAuthorId = data.authorId ?? null;\\n380\\t      postTitle = data.title ?? null;\\n381\\t      const likeCount = data.likeCount ?? 0;\\n382\\t      const dislikeCount = data.dislikeCount ?? 0;\\n383\\t      const voteCount = data.voteCount ?? 0;\\n384\\t\\n385\\t      const updatedLikeCount = likeCount + (nextValue === 1 ? 1 : 0) - (prevValue === 1 ? 1 : 0);\\n386\\t      const updatedDislikeCount =\\n387\\t        dislikeCount + (nextValue === -1 ? 1 : 0) - (prevValue === -1 ? 1 : 0);\\n388\\t      const updatedVoteCount = voteCount + (nextValue - prevValue);\\n389\\t\\n390\\t      tx.update(postRef, {\\n391\\t        likeCount: updatedLikeCount,\\n392\\t        dislikeCount: updatedDislikeCount,\\n393\\t        voteCount: updatedVoteCount,\\n394\\t      });\\n395\\t\\n396\\t      tx.set(voteRef, { value: nextValue });\\n397\\t\\n398\\t      if (prevValue !== 1 && nextValue === 1) {\\n399\\t        shouldNotify = true;\\n400\\t      }\\n401\\t    });\\n402\\t\\n403\\t    const updatedSnap = await getDoc(postRef);\\n404\\t    if (!updatedSnap.exists()) return null;\\n405\\t\\n406\\t    if (shouldNotify && postAuthorId && postAuthorId !== user.uid) {\\n407\\t      await createNotification({\\n408\\t        recipientId: postAuthorId,\\n409\\t        actorId: user.uid,\\n410\\t        type: \\'like\\',\\n411\\t        title: \\'B\u00e0i vi\u1ebft \u0111\u01b0\u1ee3c th\u00edch\\',\\n412\\t        message: `${user.displayName ?? \\'Ng\u01b0\u1eddi d\u00f9ng\\'} \u0111\u00e3 th\u00edch b\u00e0i vi\u1ebft c\u1ee7a b\u1ea1n${postTitle ? `: \"${postTitle}\"` : \\'\\'}.`,\\n413\\t        postId: likeData.postId,\\n414\\t      });\\n415\\t    }\\n416\\t\\n417\\t    const hydratedPost = await hydrateEntityUser(mapPost(updatedSnap.id, updatedSnap.data()));\\n418\\t    return applyUserVoteToPost(hydratedPost, nextValue);\\n419\\t  } catch (error) {\\n420\\t    logFirestoreError(error, `likePost(${likeData.postId})`);\\n421\\t    throw error;\\n422\\t  }\\n423\\t};\\n424\\t\\n425\\t/**\\n426\\t * Realtime theo d\u00f5i m\u1ed9t b\u00e0i \u0111\u0103ng & comment c\u1ee7a n\u00f3\\n427\\t */\\n428\\texport const subscribeToPost = (\\n429\\t  postId: string,\\n430\\t  callback: (post: Post | null) => void\\n431\\t): (() => void) => {\\n432\\t  const postRef = doc(db, \\'posts\\', postId);\\n433\\t  const commentsQuery = query(\\n434\\t    collection(db, \\'posts\\', postId, \\'comments\\'),\\n435\\t    orderBy(\\'voteCount\\', \\'desc\\')\\n436\\t  );\\n437\\t\\n438\\t  const currentUser = auth.currentUser;\\n439\\t  let postData: Post | null = null;\\n440\\t  let commentsData: Comment[] = [];\\n441\\t  let userVote: number = 0;\\n442\\t\\n443\\t  const notify = () => {\\n444\\t    if (!postData) {\\n445\\t      callback(null);\\n446\\t      return;\\n447\\t    }\\n448\\t    const orderedComments = orderComments(commentsData, postData.bestAnswerId);\\n449\\t    callback({\\n450\\t      ...postData,\\n451\\t      comments: orderedComments,\\n452\\t      userLiked: userVote === 1,\\n453\\t      userDisliked: userVote === -1,\\n454\\t    });\\n455\\t  };\\n456\\t\\n457\\t  const unsubscribePost = onSnapshot(postRef, async (snap) => {\\n458\\t    if (!snap.exists()) {\\n459\\t      postData = null;\\n460\\t      notify();\\n461\\t      return;\\n462\\t    }\\n463\\t    postData = await hydrateEntityUser(mapPost(snap.id, snap.data()));\\n464\\t    notify();\\n465\\t  }, (error) => {\\n466\\t    logFirestoreError(error, `subscribeToPost(${postId})`);\\n467\\t  });\\n468\\t\\n469\\t  const unsubscribeComments = onSnapshot(commentsQuery, async (snapshot) => {\\n470\\t    const rawComments = snapshot.docs.map((docSnap) => mapComment(docSnap.id, docSnap.data()));\\n471\\t    commentsData = await hydrateCommentsUsers(rawComments);\\n472\\t    notify();\\n473\\t  }, (error) => {\\n474\\t    logFirestoreError(error, `subscribeToPost(${postId})/comments`);\\n475\\t  });\\n476\\t\\n477\\t  let unsubscribeVote: (() => void) | null = null;\\n478\\t  if (currentUser) {\\n479\\t    const voteDoc = doc(db, \\'posts\\', postId, \\'votes\\', currentUser.uid);\\n480\\t    unsubscribeVote = onSnapshot(voteDoc, (voteSnap) => {\\n481\\t      userVote = voteSnap.exists() ? ((voteSnap.data().value as number) ?? 0) : 0;\\n482\\t      notify();\\n483\\t    }, (error) => {\\n484\\t      logFirestoreError(error, `subscribeToPost(${postId})/vote`);\\n485\\t    });\\n486\\t  }\\n487\\t\\n488\\t  return () => {\\n489\\t    unsubscribePost();\\n490\\t    unsubscribeComments();\\n491\\t    if (unsubscribeVote) unsubscribeVote();\\n492\\t  };\\n493\\t};\\n494\\t\\n495\\t/**\\n496\\t * T\u1ea1o b\u00ecnh lu\u1eadn realtime v\u00e0 t\u0103ng commentCount\\n497\\t */\\n498\\texport const createCommentRealtime = async (\\n499\\t  commentData: CreateCommentRequest\\n500\\t): Promise<Comment | null> => {\\n501\\t  const user = auth.currentUser;\\n502\\t  if (!user) return null;\\n503\\t\\n504\\t  try {\\n505\\t    const commentsCol = collection(db, \\'posts\\', commentData.postId, \\'comments\\');\\n506\\t    const commentRef = doc(commentsCol);\\n507\\t    const postRef = doc(db, \\'posts\\', commentData.postId);\\n508\\t    let postAuthorId: string | null = null;\\n509\\t    let postTitle: string | null = null;\\n510\\t\\n511\\t    await runTransaction(db, async (tx: Transaction) => {\\n512\\t      const postSnap = await tx.get(postRef);\\n513\\t      if (!postSnap.exists()) throw new Error(\\'Post not found\\');\\n514\\t      const data = postSnap.data() ?? {};\\n515\\t      postAuthorId = data.authorId ?? null;\\n516\\t      postTitle = data.title ?? null;\\n517\\t      const currentCount = data.commentCount ?? 0;\\n518\\t\\n519\\t      tx.set(commentRef, {\\n520\\t        authorId: user.uid,\\n521\\t        authorName: user.displayName ?? null,\\n522\\t        authorAvatarUrl: user.photoURL ?? null,\\n523\\t        content: commentData.content,\\n524\\t        imageUrl: commentData.imageUrl ?? null,\\n525\\t        voteCount: 0,\\n526\\t        likeCount: 0,\\n527\\t        dislikeCount: 0,\\n528\\t        createdAt: serverTimestamp(),\\n529\\t      });\\n530\\t\\n531\\t      tx.update(postRef, { commentCount: currentCount + 1 });\\n532\\t    });\\n533\\t\\n534\\t    const snap = await getDoc(commentRef);\\n535\\t    if (!snap.exists()) return null;\\n536\\t\\n537\\t    if (postAuthorId && postAuthorId !== user.uid) {\\n538\\t      await createNotification({\\n539\\t        recipientId: postAuthorId,\\n540\\t        actorId: user.uid,\\n541\\t        type: \\'comment\\',\\n542\\t        title: \\'B\u00ecnh lu\u1eadn m\u1edbi\\',\\n543\\t        message: `${user.displayName ?? \\'Ng\u01b0\u1eddi d\u00f9ng\\'} \u0111\u00e3 b\u00ecnh lu\u1eadn v\u00e0o b\u00e0i vi\u1ebft c\u1ee7a b\u1ea1n${postTitle ? `: \"${postTitle}\"` : \\'\\'}.`,\\n544\\t        postId: commentData.postId,\\n545\\t        commentId: commentRef.id,\\n546\\t      });\\n547\\t    }\\n548\\t\\n549\\t    const comment = mapComment(snap.id, snap.data());\\n550\\t    return hydrateEntityUser(comment);\\n551\\t  } catch (error) {\\n552\\t    logFirestoreError(error, `createCommentRealtime(${commentData.postId})`);\\n553\\t    throw error;\\n554\\t  }\\n555\\t};\\n556\\t\\n557\\t/**\\n558\\t * Gi\u1eef l\u1ea1i h\u00e0m createComment \u0111\u1ec3 t\u01b0\u01a1ng th\u00edch ng\u01b0\u1ee3c\\n559\\t */\\n560\\texport const createComment = createCommentRealtime;\\n561\\t\\n562\\t/**\\n563\\t * Vote b\u00ecnh lu\u1eadn (+1, -1, 0)\\n564\\t */\\n565\\texport const voteComment = async (\\n566\\t  postId: string,\\n567\\t  commentId: string,\\n568\\t  value: 1 | -1 | 0\\n569\\t): Promise<void> => {\\n570\\t  const user = auth.currentUser;\\n571\\t  if (!user) throw new Error(\\'Not authenticated\\');\\n572\\t\\n573\\t  const voteDocRef = doc(db, \\'posts\\', postId, \\'comments\\', commentId, \\'votes\\', user.uid);\\n574\\t  const commentRef = doc(db, \\'posts\\', postId, \\'comments\\', commentId);\\n575\\t\\n576\\t  try {\\n577\\t    await runTransaction(db, async (tx: Transaction) => {\\n578\\t      const voteSnap = await tx.get(voteDocRef);\\n579\\t      const prevValue = voteSnap.exists() ? ((voteSnap.data().value as number) ?? 0) : 0;\\n580\\t      const delta = value - prevValue;\\n581\\t\\n582\\t      if (delta !== 0) {\\n583\\t        const commentSnap = await tx.get(commentRef);\\n584\\t        if (!commentSnap.exists()) throw new Error(\\'Comment not found\\');\\n585\\t        const data = commentSnap.data() ?? {};\\n586\\t        const currentVoteCount = data.voteCount ?? 0;\\n587\\t        tx.update(commentRef, { voteCount: currentVoteCount + delta });\\n588\\t      }\\n589\\t\\n590\\t      tx.set(voteDocRef, { value });\\n591\\t    });\\n592\\t  } catch (error) {\\n593\\t    logFirestoreError(error, `voteComment(${postId}, ${commentId})`);\\n594\\t    throw error;\\n595\\t  }\\n596\\t};\\n597\\t\\n598\\texport const markBestAnswer = async (postId: string, commentId: string): Promise<void> => {\\n599\\t  const user = auth.currentUser;\\n600\\t  if (!user) throw new Error(\\'Not authenticated\\');\\n601\\t  const postRef = doc(db, \\'posts\\', postId);\\n602\\t  try {\\n603\\t    const snap = await getDoc(postRef);\\n604\\t    if (!snap.exists()) throw new Error(\\'Post not found\\');\\n605\\t    const data = snap.data();\\n606\\t    if (data.authorId !== user.uid) throw new Error(\\'Not post author\\');\\n607\\t    await updateDoc(postRef, { bestAnswerId: commentId });\\n608\\t  } catch (error) {\\n609\\t    logFirestoreError(error, `markBestAnswer(${postId}, ${commentId})`);\\n610\\t    throw error;\\n611\\t  }\\n612\\t};\\n613\\t\\n614\\t'}, {'role': 'tool', 'tool_call_id': 'aa84e761-6929-433a-8612-080c54cbc8fa', 'content': '1\\t// ---- LOCAL DEVELOPMENT (comment l\u1ea1i khi \u0111\u00e3 deploy) ----\\n2\\t// const API_URL = \\'http://192.168.0.106:8001\\'; // Cho Expo Go tr\u00ean \u0111i\u1ec7n tho\u1ea1i/emulator\\n3\\t// const API_URL = \\'http://10.0.2.2:8001\\'; // Cho Android emulator (kh\u00f4ng d\u00f9ng Expo Go)\\n4\\t// const API_URL = \\'http://localhost:8001\\'; // Cho web\\n5\\t\\n6\\tconst API_URL = \\'https://d515-35-247-3-221.ngrok-free.app\\';\\n7\\texport interface DiseaseInfo {\\n8\\t  name: string;\\n9\\t  description: string;\\n10\\t  treatment: string;\\n11\\t}\\n12\\t\\n13\\texport interface PredictionDetail {\\n14\\t  probability: number;\\n15\\t  label_en: string;\\n16\\t}\\n17\\t\\n18\\texport interface PredictionResult {\\n19\\t  success: boolean;\\n20\\t  predicted_class?: string;\\n21\\t  predicted_class_vi?: string;\\n22\\t  confidence?: number;\\n23\\t  disease_info?: DiseaseInfo;\\n24\\t  all_predictions?: {\\n25\\t    [key: string]: PredictionDetail;\\n26\\t  };\\n27\\t  leaf_detection_confidence?: number; // Confidence c\u1ee7a YOLO khi ph\u00e1t hi\u1ec7n l\u00e1\\n28\\t  leaf_bbox?: number[]; // T\u1ecda \u0111\u1ed9 bounding box [x1, y1, x2, y2]\\n29\\t  model_info?: {\\n30\\t    step1?: string; // \"YOLO (ph\u00e1t hi\u1ec7n l\u00e1 - ch\u1ecdn bbox l\u1edbn nh\u1ea5t)\"\\n31\\t    step2?: string; // \"DenseNet121 (ph\u00e2n lo\u1ea1i b\u1ec7nh)\"\\n32\\t    detection?: string; // Backward compatibility\\n33\\t    classification?: string; // Backward compatibility\\n34\\t  };\\n35\\t  error?: string;\\n36\\t  error_code?: string; // NO_LEAF_DETECTED, LEAF_TOO_SMALL, PREDICTION_ERROR, SERVER_ERROR\\n37\\t  suggestion?: string; // G\u1ee3i \u00fd khi c\u00f3 l\u1ed7i\\n38\\t  details?: string; // Chi ti\u1ebft l\u1ed7i\\n39\\t}\\n40\\t\\n41\\texport const predictDisease = async (imageUri: string): Promise<PredictionResult | null> => {\\n42\\t  try {\\n43\\t    console.log(\\'\ud83d\udd04 \u0110ang g\u1eedi \u1ea3nh \u0111\u1ebfn API...\\');\\n44\\t    console.log(\\'\ud83d\udcf7 URI:\\', imageUri);\\n45\\t    console.log(\\'\ud83c\udf10 API URL:\\', `${API_URL}/predict`);\\n46\\t\\n47\\t    // T\u1ea1o FormData \u0111\u1ec3 upload \u1ea3nh\\n48\\t    const formData = new FormData();\\n49\\t\\n50\\t    // L\u1ea5y t\u00ean file t\u1eeb URI\\n51\\t    const uriParts = imageUri.split(\\'/\\');\\n52\\t    const filename = uriParts[uriParts.length - 1];\\n53\\t\\n54\\t    // X\u00e1c \u0111\u1ecbnh type t\u1eeb extension\\n55\\t    let type = \\'image/jpeg\\';\\n56\\t    if (filename.endsWith(\\'.png\\')) type = \\'image/png\\';\\n57\\t    else if (filename.endsWith(\\'.jpg\\') || filename.endsWith(\\'.jpeg\\')) type = \\'image/jpeg\\';\\n58\\t\\n59\\t    // Append file v\u1edbi format React Native y\u00eau c\u1ea7u\\n60\\t    formData.append(\\'file\\', {\\n61\\t      uri: imageUri,\\n62\\t      name: filename,\\n63\\t      type: type,\\n64\\t    } as any);\\n65\\t\\n66\\t    console.log(\\'\ufffd Uploading file:\\', filename, \\'Type:\\', type);\\n67\\t    console.log(\\'\ud83d\udce4 Full API URL:\\', `${API_URL}/predict`);\\n68\\t\\n69\\t    const apiResponse = await fetch(`${API_URL}/predict`, {\\n70\\t      method: \\'POST\\',\\n71\\t      body: formData,\\n72\\t      headers: {\\n73\\t        \\'Accept\\': \\'application/json\\',\\n74\\t        \\'ngrok-skip-browser-warning\\': \\'true\\',\\n75\\t      },\\n76\\t    });\\n77\\t\\n78\\t    console.log(\\'\ud83d\udce5 Response status:\\', apiResponse.status);\\n79\\t    console.log(\\'\ud83d\udce5 Response ok:\\', apiResponse.ok);\\n80\\t    console.log(\\'\ud83d\udce5 Content-Type:\\', apiResponse.headers.get(\\'content-type\\'));\\n81\\t\\n82\\t    if (!apiResponse.ok) {\\n83\\t      const errorText = await apiResponse.text();\\n84\\t      console.error(\\'\u274c API Error Response:\\', errorText);\\n85\\t      throw new Error(`API request failed with status: ${apiResponse.status}`);\\n86\\t    }\\n87\\t\\n88\\t    // Ki\u1ec3m tra content-type tr\u01b0\u1edbc khi parse JSON\\n89\\t    const contentType = apiResponse.headers.get(\\'content-type\\');\\n90\\t    if (!contentType || !contentType.includes(\\'application/json\\')) {\\n91\\t      const text = await apiResponse.text();\\n92\\t      console.error(\\'\u274c API tr\u1ea3 v\u1ec1 kh\u00f4ng ph\u1ea3i JSON:\\');\\n93\\t      console.error(\\'Content-Type:\\', contentType);\\n94\\t      console.error(\\'Response preview:\\', text.substring(0, 300));\\n95\\t      throw new Error(\\'API tr\u1ea3 v\u1ec1 HTML thay v\u00ec JSON. Ki\u1ec3m tra ngrok URL ho\u1eb7c server status!\\');\\n96\\t    }\\n97\\t\\n98\\t    const result: PredictionResult = await apiResponse.json();\\n99\\t    console.log(\\'\u2705 Prediction result:\\', result);\\n100\\t\\n101\\t    // X\u1eed l\u00fd c\u00e1c error codes t\u1eeb API\\n102\\t    if (!result.success) {\\n103\\t      console.warn(\\'\u26a0\ufe0f Prediction kh\u00f4ng th\u00e0nh c\u00f4ng:\\', result.error_code);\\n104\\t\\n105\\t      if (result.error_code === \\'NO_LEAF_DETECTED\\') {\\n106\\t        console.warn(\\'\ud83c\udf43 Kh\u00f4ng ph\u00e1t hi\u1ec7n l\u00e1 n\u00e0o trong \u1ea3nh\\');\\n107\\t        console.warn(\\'\ud83d\udca1 G\u1ee3i \u00fd:\\', result.suggestion);\\n108\\t      } else if (result.error_code === \\'LEAF_TOO_SMALL\\') {\\n109\\t        console.warn(\\'\ud83d\udccf V\u00f9ng l\u00e1 ph\u00e1t hi\u1ec7n qu\u00e1 nh\u1ecf\\');\\n110\\t        console.warn(\\'\ud83d\udca1 G\u1ee3i \u00fd:\\', result.suggestion);\\n111\\t      } else if (result.error_code === \\'PREDICTION_ERROR\\') {\\n112\\t        console.error(\\'\u274c L\u1ed7i khi d\u1ef1 \u0111o\u00e1n b\u1ec7nh\\');\\n113\\t      }\\n114\\t    } else {\\n115\\t      console.log(\\'\u2705 Quy tr\u00ecnh 2 b\u01b0\u1edbc ho\u00e0n t\u1ea5t:\\');\\n116\\t      console.log(\\'   1\ufe0f\u20e3 YOLO detect l\u00e1 \u2192\\', result.model_info?.step1 || result.model_info?.detection || \\'Detected\\');\\n117\\t      console.log(\\'   2\ufe0f\u20e3 DenseNet classify \u2192\\', result.model_info?.step2 || result.model_info?.classification || \\'Classified\\');\\n118\\t      console.log(\\'\ud83c\udf43 Leaf detection confidence:\\', result.leaf_detection_confidence);\\n119\\t      if (result.leaf_bbox) {\\n120\\t        const [x1, y1, x2, y2] = result.leaf_bbox;\\n121\\t        console.log(\\'\ud83d\udce6 Leaf bounding box:\\', `(${x1}, ${y1}) \u2192 (${x2}, ${y2})`);\\n122\\t      }\\n123\\t    }\\n124\\t\\n125\\t    return result;\\n126\\t  } catch (error) {\\n127\\t    console.error(\\'\u274c Error predicting disease:\\', error);\\n128\\t    console.error(\\'\u274c Error name:\\', (error as Error).name);\\n129\\t    console.error(\\'\u274c Error message:\\', (error as Error).message);\\n130\\t    if ((error as any).stack) {\\n131\\t      console.error(\\'\u274c Stack trace:\\', (error as any).stack);\\n132\\t    }\\n133\\t    return null;\\n134\\t  }\\n135\\t};\\n136\\t\\n137\\texport const checkAPIStatus = async (): Promise<boolean> => {\\n138\\t  try {\\n139\\t    console.log(\\'\ud83d\udd0d \u0110ang ki\u1ec3m tra API status t\u1ea1i:\\', `${API_URL}/`);\\n140\\t\\n141\\t    const response = await fetch(`${API_URL}/`, {\\n142\\t      method: \\'GET\\',\\n143\\t      headers: {\\n144\\t        \\'Accept\\': \\'application/json\\',\\n145\\t        \\'ngrok-skip-browser-warning\\': \\'true\\', // B\u1ecf qua ngrok warning page\\n146\\t      },\\n147\\t    });\\n148\\t\\n149\\t    console.log(\\'\ud83d\udce5 Response status:\\', response.status);\\n150\\t    console.log(\\'\ud83d\udce5 Response ok:\\', response.ok);\\n151\\t    console.log(\\'\ud83d\udce5 Content-Type:\\', response.headers.get(\\'content-type\\'));\\n152\\t\\n153\\t    // Ki\u1ec3m tra content-type tr\u01b0\u1edbc khi parse JSON\\n154\\t    const contentType = response.headers.get(\\'content-type\\');\\n155\\t    if (!contentType || !contentType.includes(\\'application/json\\')) {\\n156\\t      const text = await response.text();\\n157\\t      console.error(\\'\u274c API tr\u1ea3 v\u1ec1 kh\u00f4ng ph\u1ea3i JSON:\\');\\n158\\t      console.error(\\'Content-Type:\\', contentType);\\n159\\t      console.error(\\'Response preview:\\', text.substring(0, 200));\\n160\\t\\n161\\t      // Ki\u1ec3m tra n\u1ebfu l\u00e0 ngrok warning page\\n162\\t      if (text.includes(\\'ngrok\\') || text.includes(\\'Tunnel\\') || text.includes(\\'<!DOCTYPE\\')) {\\n163\\t        console.error(\\'\u26a0\ufe0f C\u00f3 v\u1ebb \u0111\u00e2y l\u00e0 ngrok warning page!\\');\\n164\\t        console.error(\\'\ud83d\udca1 Gi\u1ea3i ph\u00e1p:\\');\\n165\\t        console.error(\\'   1. Th\u00eam header \"ngrok-skip-browser-warning: true\"\\');\\n166\\t        console.error(\\'   2. Ho\u1eb7c truy c\u1eadp URL trong browser 1 l\u1ea7n \u0111\u1ec3 verify\\');\\n167\\t      }\\n168\\t\\n169\\t      return false;\\n170\\t    }\\n171\\t\\n172\\t    const data = await response.json();\\n173\\t    console.log(\\'\u2705 API Status:\\', data);\\n174\\t    console.log(\\'\u2705 API version:\\', data.version);\\n175\\t    console.log(\\'\u2705 Models:\\', data.models);\\n176\\t\\n177\\t    return response.ok;\\n178\\t  } catch (error) {\\n179\\t    console.error(\\'\u274c API kh\u00f4ng kh\u1ea3 d\u1ee5ng:\\', error);\\n180\\t    console.error(\\'\u274c API URL:\\', API_URL);\\n181\\t    console.error(\\'\ud83d\udca1 Ki\u1ec3m tra:\\');\\n182\\t    console.error(\\'   1. Server \u0111\u00e3 ch\u1ea1y ch\u01b0a?\\');\\n183\\t    console.error(\\'   2. URL ngrok \u0111\u00fang ch\u01b0a?\\');\\n184\\t    console.error(\\'   3. Ngrok session c\u00f2n active kh\u00f4ng?\\');\\n185\\t\\n186\\t    if (error instanceof SyntaxError) {\\n187\\t      console.error(\\'\u26a0\ufe0f L\u1ed7i parse JSON - API c\u00f3 th\u1ec3 tr\u1ea3 v\u1ec1 HTML thay v\u00ec JSON\\');\\n188\\t    }\\n189\\t\\n190\\t    return false;\\n191\\t  }\\n192\\t};\\n193\\t\\n194\\texport interface BatchPredictionResult {\\n195\\t  filename: string;\\n196\\t  success: boolean;\\n197\\t  predicted_class?: string;\\n198\\t  predicted_class_vi?: string;\\n199\\t  confidence?: number;\\n200\\t  disease_info?: DiseaseInfo;\\n201\\t  all_predictions?: {\\n202\\t    [key: string]: PredictionDetail;\\n203\\t  };\\n204\\t  leaf_detection_confidence?: number; // Confidence c\u1ee7a YOLO\\n205\\t  leaf_bbox?: number[]; // T\u1ecda \u0111\u1ed9 bounding box [x1, y1, x2, y2]\\n206\\t  model_info?: {\\n207\\t    step1?: string;\\n208\\t    step2?: string;\\n209\\t    detection?: string;\\n210\\t    classification?: string;\\n211\\t  };\\n212\\t  error?: string;\\n213\\t  error_code?: string; // NO_LEAF_DETECTED, LEAF_TOO_SMALL, etc.\\n214\\t  suggestion?: string;\\n215\\t  imageUri?: string; // \u0110\u1ec3 hi\u1ec3n th\u1ecb \u1ea3nh g\u1ed1c\\n216\\t}\\n217\\t\\n218\\texport interface BatchResponse {\\n219\\t  success: boolean;\\n220\\t  processed: number;\\n221\\t  failed: number;\\n222\\t  no_leaf_detected?: number; // S\u1ed1 \u1ea3nh kh\u00f4ng ph\u00e1t hi\u1ec7n l\u00e1\\n223\\t  leaf_too_small?: number; // S\u1ed1 \u1ea3nh c\u00f3 v\u00f9ng l\u00e1 qu\u00e1 nh\u1ecf\\n224\\t  total: number;\\n225\\t  results: BatchPredictionResult[];\\n226\\t  model?: string; // \"YOLOv8m-seg + DenseNet121\"\\n227\\t  error?: string;\\n228\\t  error_code?: string;\\n229\\t}\\n230\\t\\n231\\texport const predictDiseasesBatch = async (imageUris: string[]): Promise<BatchResponse | null> => {\\n232\\t  try {\\n233\\t    console.log(\\'\ud83d\udd04 \u0110ang g\u1eedi nhi\u1ec1u \u1ea3nh \u0111\u1ebfn API...\\');\\n234\\t    console.log(\\'\ud83d\udcf7 S\u1ed1 l\u01b0\u1ee3ng \u1ea3nh:\\', imageUris.length);\\n235\\t    console.log(\\'\ud83c\udf10 API URL:\\', `${API_URL}/predict-batch`);\\n236\\t\\n237\\t    const formData = new FormData();\\n238\\t\\n239\\t    // Th\u00eam t\u1ea5t c\u1ea3 \u1ea3nh v\u00e0o FormData\\n240\\t    for (let i = 0; i < imageUris.length; i++) {\\n241\\t      const imageUri = imageUris[i];\\n242\\t      const uriParts = imageUri.split(\\'/\\');\\n243\\t      const filename = uriParts[uriParts.length - 1] || `image_${i}.jpg`;\\n244\\t\\n245\\t      let type = \\'image/jpeg\\';\\n246\\t      if (filename.endsWith(\\'.png\\')) type = \\'image/png\\';\\n247\\t      else if (filename.endsWith(\\'.jpg\\') || filename.endsWith(\\'.jpeg\\')) type = \\'image/jpeg\\';\\n248\\t\\n249\\t      formData.append(\\'files\\', {\\n250\\t        uri: imageUri,\\n251\\t        name: filename,\\n252\\t        type: type,\\n253\\t      } as any);\\n254\\t    }\\n255\\t\\n256\\t    console.log(\\'\ud83d\udce4 Uploading\\', imageUris.length, \\'images...\\');\\n257\\t\\n258\\t    const apiResponse = await fetch(`${API_URL}/predict-batch`, {\\n259\\t      method: \\'POST\\',\\n260\\t      body: formData,\\n261\\t      headers: {\\n262\\t        \\'Accept\\': \\'application/json\\',\\n263\\t        \\'ngrok-skip-browser-warning\\': \\'true\\', // Th\u00eam header cho batch endpoint\\n264\\t      },\\n265\\t    });\\n266\\t\\n267\\t    console.log(\\'\ud83d\udce5 Response status:\\', apiResponse.status);\\n268\\t    console.log(\\'\ud83d\udce5 Response ok:\\', apiResponse.ok);\\n269\\t    console.log(\\'\ud83d\udce5 Content-Type:\\', apiResponse.headers.get(\\'content-type\\'));\\n270\\t\\n271\\t    if (!apiResponse.ok) {\\n272\\t      const errorText = await apiResponse.text();\\n273\\t      console.error(\\'\u274c API Error Response:\\', errorText);\\n274\\t      throw new Error(`API request failed with status: ${apiResponse.status}`);\\n275\\t    }\\n276\\t\\n277\\t    // Ki\u1ec3m tra content-type\\n278\\t    const contentType = apiResponse.headers.get(\\'content-type\\');\\n279\\t    if (!contentType || !contentType.includes(\\'application/json\\')) {\\n280\\t      const text = await apiResponse.text();\\n281\\t      console.error(\\'\u274c Batch API tr\u1ea3 v\u1ec1 kh\u00f4ng ph\u1ea3i JSON\\');\\n282\\t      console.error(\\'Response preview:\\', text.substring(0, 300));\\n283\\t      throw new Error(\\'API tr\u1ea3 v\u1ec1 HTML thay v\u00ec JSON!\\');\\n284\\t    }\\n285\\t\\n286\\t    const result: BatchResponse = await apiResponse.json();\\n287\\t\\n288\\t    // Th\u00eam imageUri v\u00e0o m\u1ed7i result \u0111\u1ec3 hi\u1ec3n th\u1ecb\\n289\\t    result.results = result.results.map((r, idx) => ({\\n290\\t      ...r,\\n291\\t      imageUri: imageUris[idx]\\n292\\t    }));\\n293\\t\\n294\\t    console.log(\\'\u2705 Batch prediction result:\\', result);\\n295\\t\\n296\\t    return result;\\n297\\t  } catch (error) {\\n298\\t    console.error(\\'\u274c Error predicting diseases batch:\\', error);\\n299\\t    console.error(\\'\u274c Error name:\\', (error as Error).name);\\n300\\t    console.error(\\'\u274c Error message:\\', (error as Error).message);\\n301\\t    if ((error as any).stack) {\\n302\\t      console.error(\\'\u274c Stack trace:\\', (error as any).stack);\\n303\\t    }\\n304\\t    return null;\\n305\\t  }\\n306\\t};\\n307\\t'}, {'role': 'assistant', 'content': '<tool_call>Bash<arg_key>command</arg_key><arg_value>ls -la CropWise/constants/</arg_value><arg_key>description</arg_key><arg_value>List constants directory</arg_value></tool_call>', 'reasoning_content': 'Now I have a good understanding of the codebase. Let me look at a few more files to understand the complete architecture before creating the CLAUDE.md file.', 'tool_calls': [{'id': '30c5d1a3-4319-4719-aef4-01fec05ec32b', 'type': 'function', 'function': {'name': 'Read', 'arguments': '{\"file_path\": \"c:\\\\\\\\Users\\\\\\\\CHINH\\\\\\\\OneDrive\\\\\\\\M\\\\u00e1y t\\\\u00ednh\\\\\\\\AI_For_Life_CropWise\\\\\\\\CropWise\\\\\\\\app.json\"}'}}, {'id': '9386e980-d503-4d67-88d4-f2659a0ce946', 'type': 'function', 'function': {'name': 'Bash', 'arguments': '{\"command\": \"ls -la CropWise/model/\", \"description\": \"List model directory\"}'}}]}, {'role': 'tool', 'tool_call_id': '30c5d1a3-4319-4719-aef4-01fec05ec32b', 'content': '1\\t{\\n2\\t  \"expo\": {\\n3\\t    \"name\": \"CropWise\",\\n4\\t    \"slug\": \"CropWise\",\\n5\\t    \"version\": \"1.0.0\",\\n6\\t    \"orientation\": \"portrait\",\\n7\\t    \"icon\": \"./assets/images/icon.png\",\\n8\\t    \"scheme\": \"cropwise\",\\n9\\t    \"userInterfaceStyle\": \"automatic\",\\n10\\t    \"newArchEnabled\": true,\\n11\\t    \"ios\": {\\n12\\t      \"supportsTablet\": true\\n13\\t    },\\n14\\t    \"android\": {\\n15\\t      \"adaptiveIcon\": {\\n16\\t        \"backgroundColor\": \"#E6F4FE\",\\n17\\t        \"foregroundImage\": \"./assets/images/android-icon-foreground.png\",\\n18\\t        \"backgroundImage\": \"./assets/images/android-icon-background.png\",\\n19\\t        \"monochromeImage\": \"./assets/images/android-icon-monochrome.png\"\\n20\\t      },\\n21\\t      \"edgeToEdgeEnabled\": true,\\n22\\t      \"predictiveBackGestureEnabled\": false\\n23\\t    },\\n24\\t    \"web\": {\\n25\\t      \"output\": \"static\",\\n26\\t      \"favicon\": \"./assets/images/favicon.png\"\\n27\\t    },\\n28\\t    \"plugins\": [\\n29\\t      \"expo-router\",\\n30\\t      [\\n31\\t        \"expo-splash-screen\",\\n32\\t        {\\n33\\t          \"image\": \"./assets/images/splash-icon.png\",\\n34\\t          \"imageWidth\": 200,\\n35\\t          \"resizeMode\": \"contain\",\\n36\\t          \"backgroundColor\": \"#ffffff\",\\n37\\t          \"dark\": {\\n38\\t            \"backgroundColor\": \"#000000\"\\n39\\t          }\\n40\\t        }\\n41\\t      ],\\n42\\t      \"expo-web-browser\",\\n43\\t      \"expo-secure-store\"\\n44\\t    ],\\n45\\t    \"experiments\": {\\n46\\t      \"typedRoutes\": true,\\n47\\t      \"reactCompiler\": true\\n48\\t    }\\n49\\t  }\\n50\\t}\\n51\\t'}, {'role': 'tool', 'tool_call_id': '9386e980-d503-4d67-88d4-f2659a0ce946', 'content': 'total 48317\\ndrwxr-xr-x 1 CHINH 197609        0 Mar  3 17:45 .\\ndrwxr-xr-x 1 CHINH 197609        0 Mar 22 10:46 ..\\n-rw-r--r-- 1 CHINH 197609    31249 Mar  3 17:45 CropWise_API_Colab.ipynb\\n-rw-r--r-- 1 CHINH 197609  4631408 Mar  3 17:45 NewMaizeDetect.ipynb\\ndrwxr-xr-x 1 CHINH 197609        0 Mar  3 17:45 __pycache__\\n-rw-r--r-- 1 CHINH 197609     4698 Mar  3 17:45 app.py\\n-rw-r--r-- 1 CHINH 197609 44786763 Mar  3 17:45 model.pth\\n-rw-r--r-- 1 CHINH 197609      126 Mar  3 17:45 requirements.txt'}, {'role': 'assistant', 'content': '', 'reasoning_content': 'Now I have a comprehensive understanding of the codebase. Let me create the CLAUDE.md file with all the important information about the architecture, commands, and structure.\\n\\nKey points to include:\\n1. This is an Expo React Native app for crop disease detection and farming community\\n2. Uses Firebase for authentication and Firestore for data\\n3. Uses Cloudinary for image storage\\n4. Has a Python backend for disease prediction using YOLO + DenseNet\\n5. File-based routing with expo-router\\n6. Glass morphism UI components\\n7. Real-time features with Firestore subscriptions\\n8. Authentication context for user management\\n9. Services layer for API calls and data management\\n10. TypeScript for type safety\\n\\nLet me create the CLAUDE.md file now.', 'tool_calls': [{'id': 'a260bf67-7bce-46f6-a05c-444a4c085d26', 'type': 'function', 'function': {'name': 'Write', 'arguments': '{\"file_path\": \"c:\\\\\\\\Users\\\\\\\\CHINH\\\\\\\\OneDrive\\\\\\\\M\\\\u00e1y t\\\\u00ednh\\\\\\\\AI_For_Life_CropWise\\\\\\\\CLAUDE.md\", \"content\": \"# CLAUDE.md\\\\n\\\\nThis file provides guidance to Claude Code (claude.ai/code) when working with code in this repository.\\\\n\\\\n## Project Overview\\\\n\\\\nCropWise is a React Native Expo application for crop disease detection and farming community features. The app combines AI-powered disease prediction with social features for farmers to share knowledge and experiences.\\\\n\\\\n## Development Commands\\\\n\\\\n### Expo Development\\\\n```bash\\\\ncd CropWise\\\\nnpm install              # Install dependencies\\\\nnpm start              # Start Expo development server\\\\nnpm run android        # Run on Android emulator/device\\\\nnpm run ios            # Run on iOS simulator\\\\nnpm run web            # Run in web browser\\\\nnpm run lint           # Run ESLint\\\\n```\\\\n\\\\n### Backend (Python Disease Detection)\\\\nThe disease detection API is in `CropWise/model/`:\\\\n```bash\\\\ncd CropWise/model\\\\npip install -r requirements.txt\\\\npython app.py          # Start the disease detection API server\\\\n```\\\\n\\\\nThe API runs on port 8001 and is currently exposed via ngrok for mobile development.\\\\n\\\\n## Architecture\\\\n\\\\n### Tech Stack\\\\n- **Frontend**: React Native with Expo Router (file-based routing)\\\\n- **Backend**: Firebase (Auth, Firestore) + Python FastAPI for disease detection\\\\n- **Storage**: Cloudinary for images\\\\n- **State Management**: React Context (AuthContext)\\\\n- **UI**: Custom glass morphism components with expo-blur\\\\n\\\\n### Directory Structure\\\\n\\\\n```\\\\nCropWise/\\\\n\\\\u251c\\\\u2500\\\\u2500 app/                    # File-based routing (Expo Router)\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 (tabs)/            # Tab-based navigation\\\\n\\\\u2502   \\\\u2502   \\\\u251c\\\\u2500\\\\u2500 index.tsx      # Home/Crop selection\\\\n\\\\u2502   \\\\u2502   \\\\u251c\\\\u2500\\\\u2500 my-field.tsx   # Field management\\\\n\\\\u2502   \\\\u2502   \\\\u251c\\\\u2500\\\\u2500 fertilizer.tsx # Fertilizer calculator\\\\n\\\\u2502   \\\\u2502   \\\\u251c\\\\u2500\\\\u2500 community.tsx  # Community feed\\\\n\\\\u2502   \\\\u2502   \\\\u2514\\\\u2500\\\\u2500 profile.tsx    # User profile\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 community/         # Community features\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 diseases/          # Disease detection results\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 login.tsx          # Authentication\\\\n\\\\u2502   \\\\u2514\\\\u2500\\\\u2500 _layout.tsx        # Root layout with providers\\\\n\\\\u251c\\\\u2500\\\\u2500 components/\\\\n\\\\u2502   \\\\u2514\\\\u2500\\\\u2500 ui/               # Reusable UI components (GlassBackground, GlassCard, GlassInput)\\\\n\\\\u251c\\\\u2500\\\\u2500 contexts/\\\\n\\\\u2502   \\\\u2514\\\\u2500\\\\u2500 AuthContext.tsx   # Authentication state management\\\\n\\\\u251c\\\\u2500\\\\u2500 services/            # API and data services\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 firebase.ts      # Firebase initialization\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 authService.ts   # Authentication logic\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 communityService.ts  # Community posts/comments\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 diseaseService.ts     # Disease prediction API\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 cloudinaryService.ts  # Image upload\\\\n\\\\u2502   \\\\u2514\\\\u2500\\\\u2500 notificationService.ts # Push notifications\\\\n\\\\u251c\\\\u2500\\\\u2500 types/               # TypeScript interfaces\\\\n\\\\u251c\\\\u2500\\\\u2500 model/              # Python disease detection backend\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 app.py         # FastAPI server\\\\n\\\\u2502   \\\\u251c\\\\u2500\\\\u2500 model.pth      # Trained model weights\\\\n\\\\u2502   \\\\u2514\\\\u2500\\\\u2500 requirements.txt\\\\n\\\\u2514\\\\u2500\\\\u2500 firestore.rules    # Firestore security rules\\\\n```\\\\n\\\\n### Key Architectural Patterns\\\\n\\\\n#### Authentication Flow\\\\n- Firebase Auth handles user authentication\\\\n- `AuthContext` provides global auth state via `useAuth()` hook\\\\n- Auth state changes trigger automatic UI updates (login/logout redirects)\\\\n- AsyncStorage persists auth tokens on mobile\\\\n\\\\n#### Data Layer\\\\n- **Firestore**: Real-time database for posts, comments, users, notifications\\\\n- **Services Pattern**: Each feature has a dedicated service file with CRUD operations\\\\n- **Real-time Subscriptions**: `subscribeTo*` functions for live updates\\\\n- **Transactions**: Used for atomic operations (likes, comment counts)\\\\n\\\\n#### Disease Detection Pipeline\\\\n1. User selects/takes photo of crop leaf\\\\n2. Image uploaded to Python API via `diseaseService.predictDisease()`\\\\n3. Two-step process:\\\\n   - YOLOv8m-seg detects leaf regions\\\\n   - DenseNet121 classifies disease from detected leaf\\\\n4. Results include confidence scores, bounding boxes, and treatment info\\\\n\\\\n#### Community Features\\\\n- Posts support multiple images, crop type tags, and voting\\\\n- Comments can be voted and marked as \\\\\"best answer\\\\\"\\\\n- Real-time updates via Firestore listeners\\\\n- Notifications for likes and comments\\\\n- User reputation system\\\\n\\\\n#### UI Components\\\\n- Glass morphism design pattern (GlassBackground, GlassCard, GlassInput)\\\\n- expo-blur for frosted glass effects\\\\n- Safe area handling for notched devices\\\\n- Responsive tab navigation with blur backgrounds\\\\n\\\\n### Firebase Collections\\\\n\\\\n- **users**: User profiles (name, avatar, reputation)\\\\n- **posts**: Community posts with metadata\\\\n- **posts/{postId}/comments**: Nested comments\\\\n- **posts/{postId}/votes**: User votes on posts\\\\n- **posts/{postId}/comments/{commentId}/votes**: User votes on comments\\\\n- **notifications**: User notifications\\\\n- **fields**: User\\'s field data\\\\n\\\\n### API Configuration\\\\n\\\\nThe disease detection API URL is configured in `services/diseaseService.ts`:\\\\n- Development: Uses ngrok tunnel for mobile access\\\\n- Local development: Uncomment appropriate URL based on target platform\\\\n- Endpoints: `/predict` (single image), `/predict-batch` (multiple images)\\\\n\\\\n### Important Notes\\\\n\\\\n- **File-based routing**: Routes are automatically generated from `app/` directory structure\\\\n- **Type safety**: All services use TypeScript interfaces from `types/` directory\\\\n- **Error handling**: Services include comprehensive error logging with context\\\\n- **Image handling**: Cloudinary for storage, local URIs for preview before upload\\\\n- **Real-time features**: Use `subscribeTo*` functions instead of one-time fetches for live data\\\\n- **Authentication checks**: Many components redirect to `/login` if user is not authenticated\\\\n- **Platform differences**: Firebase initialization differs between web and mobile (AsyncStorage persistence)\\\\n\\\\n### Testing Disease Detection\\\\n\\\\nTo test the disease detection feature:\\\\n1. Start the Python backend: `cd CropWise/model && python app.py`\\\\n2. Update `API_URL` in `services/diseaseService.ts` if needed\\\\n3. Use the app to capture/select leaf images\\\\n4. Check console logs for detailed prediction pipeline information\\\\n\\\\n### Firestore Security\\\\n\\\\nThe app uses Firestore security rules defined in `firestore.rules` to ensure:\\\\n- Users can only read/write their own data\\\\n- Community posts are publicly readable but only authors can edit\\\\n- Proper authentication is required for write operations\"}'}}]}, {'role': 'tool', 'tool_call_id': 'a260bf67-7bce-46f6-a05c-444a4c085d26', 'content': 'File created successfully at: c:\\\\Users\\\\CHINH\\\\OneDrive\\\\M\u00e1y t\u00ednh\\\\AI_For_Life_CropWise\\\\CLAUDE.md (file state is current in your context \u2014 no need to Read it back)'}, {'role': 'assistant', 'content': 'I\\'ve created a comprehensive [CLAUDE.md](c:\\\\Users\\\\CHINH\\\\OneDrive\\\\M\u00e1y t\u00ednh\\\\AI_For_Life_CropWise\\\\CLAUDE.md) file for the CropWise repository. The documentation includes:\\n\\n**Key sections:**\\n- **Project Overview**: React Native Expo app for crop disease detection and farming community\\n- **Development Commands**: Instructions for running both the Expo frontend and Python backend\\n- **Architecture**: Detailed breakdown of the tech stack, directory structure, and key patterns\\n- **Authentication Flow**: Firebase Auth with React Context for global state management\\n- **Data Layer**: Firestore real-time database with service pattern\\n- **Disease Detection Pipeline**: Two-step AI process using YOLO + DenseNet\\n- **Community Features**: Posts, comments, voting, and real-time updates\\n- **Firebase Collections**: Database structure and relationships\\n- **API Configuration**: Disease detection API setup and endpoints\\n- **Important Notes**: File-based routing, TypeScript safety, error handling, and platform differences\\n\\nThe documentation focuses on the \"big picture\" architecture that requires reading multiple files to understand, rather than listing every component or obvious development practices.', 're