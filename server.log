0]!;\\n41\\t  db = getFirestore(app);\\n42\\t}\\n43\\t\\n44\\tif (__DEV__) {\\n45\\t  setLogLevel(\\'debug\\');\\n46\\t}\\n47\\t\\n48\\tlet auth: Auth;\\n49\\tif (Platform.OS === \\'web\\') {\\n50\\t  auth = getAuth(app);\\n51\\t} else {\\n52\\t  try {\\n53\\t    // eslint-disable-next-line @typescript-eslint/no-var-requires\\n54\\t    const { getReactNativePersistence } = require(\\'firebase/auth/react-native\\');\\n55\\t    auth = initializeAuth(app, {\\n56\\t      persistence: getReactNativePersistence(AsyncStorage),\\n57\\t    });\\n58\\t  } catch {\\n59\\t    try {\\n60\\t      auth = initializeAuth(app);\\n61\\t    } catch {\\n62\\t      auth = getAuth(app);\\n63\\t    }\\n64\\t  }\\n65\\t}\\n66\\t\\n67\\texport { app, auth, db };\\n68\\t'}, {'role': 'tool', 'tool_call_id': 'c913f37b-216f-46a3-87aa-b36bf5f5bae0', 'content': \"1\\timport { User as FirebaseUser, onAuthStateChanged, signOut } from 'firebase/auth';\\n2\\timport React, { createContext, useCallback, useContext, useEffect, useMemo, useState } from 'react';\\n3\\timport {\\n4\\t    getUserFromFirebaseUser,\\n5\\t    login as loginApi,\\n6\\t    register as registerApi,\\n7\\t    resetPassword as resetPasswordApi\\n8\\t} from '../services/authService';\\n9\\timport { auth } from '../services/firebase';\\n10\\t\\n11\\ttype AuthUser = {\\n12\\t  id: string;\\n13\\t  name: string;\\n14\\t  email: string;\\n15\\t};\\n16\\t\\n17\\ttype AuthContextValue = {\\n18\\t  user: AuthUser | null;\\n19\\t  token: string | null;\\n20\\t  initializing: boolean;\\n21\\t  login: (email: string, password: string) => Promise<void>;\\n22\\t  register: (name: string, email: string, password: string) => Promise<void>;\\n23\\t  logout: () => Promise<void>;\\n24\\t  resetPassword: (email: string) => Promise<void>;\\n25\\t};\\n26\\t\\n27\\tconst AuthContext = createContext<AuthContextValue | undefined>(undefined);\\n28\\t\\n29\\texport const AuthProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {\\n30\\t  const [token, setToken] = useState<string | null>(null);\\n31\\t  const [user, setUser] = useState<AuthUser | null>(null);\\n32\\t  const [initializing, setInitializing] = useState<boolean>(true);\\n33\\t\\n34\\t  // L\u1eafng nghe thay \u0111\u1ed5i tr\u1ea1ng th\u00e1i x\u00e1c th\u1ef1c c\u1ee7a Firebase\\n35\\t  useEffect(() => {\\n36\\t    const unsubscribe = onAuthStateChanged(auth, async (firebaseUser: FirebaseUser | null) => {\\n37\\t      try {\\n38\\t        if (firebaseUser) {\\n39\\t          // User \u0111\u00e3 \u0111\u0103ng nh\u1eadp\\n40\\t          const userProfile = await getUserFromFirebaseUser(firebaseUser);\\n41\\t          const idToken = await firebaseUser.getIdToken();\\n42\\t          setUser(userProfile);\\n43\\t          setToken(idToken);\\n44\\t        } else {\\n45\\t          // User \u0111\u00e3 \u0111\u0103ng xu\u1ea5t\\n46\\t          setUser(null);\\n47\\t          setToken(null);\\n48\\t        }\\n49\\t      } catch (error) {\\n50\\t        console.error('Error in auth state change:', error);\\n51\\t        setUser(null);\\n52\\t        setToken(null);\\n53\\t      } finally {\\n54\\t        setInitializing(false);\\n55\\t      }\\n56\\t    });\\n57\\t\\n58\\t    return unsubscribe; // Cleanup subscription on unmount\\n59\\t  }, []);\\n60\\t\\n61\\t  const login = useCallback(async (email: string, password: string) => {\\n62\\t    const res = await loginApi({ email, password });\\n63\\t    // Auth state s\u1ebd \u0111\u01b0\u1ee3c c\u1eadp nh\u1eadt t\u1ef1 \u0111\u1ed9ng b\u1edfi onAuthStateChanged\\n64\\t    // Kh\u00f4ng c\u1ea7n set state \u1edf \u0111\u00e2y v\u00ec Firebase s\u1ebd t\u1ef1 \u0111\u1ed9ng trigger onAuthStateChanged\\n65\\t  }, []);\\n66\\t\\n67\\t  const register = useCallback(async (name: string, email: string, password: string) => {\\n68\\t    const res = await registerApi({ name, email, password });\\n69\\t    // Auth state s\u1ebd \u0111\u01b0\u1ee3c c\u1eadp nh\u1eadt t\u1ef1 \u0111\u1ed9ng b\u1edfi onAu