st [token, setToken] = useState<string | null>(null);\\n31\\t  const [user, setUser] = useState<AuthUser | null>(null);\\n32\\t  const [initializing, setInitializing] = useState<boolean>(true);\\n33\\t\\n34\\t  // L\u1eafng nghe thay \u0111\u1ed5i tr\u1ea1ng th\u00e1i x\u00e1c th\u1ef1c c\u1ee7a Firebase\\n35\\t  useEffect(() => {\\n36\\t    const unsubscribe = onAuthStateChanged(auth, async (firebaseUser: FirebaseUser | null) => {\\n37\\t      try {\\n38\\t        if (firebaseUser) {\\n39\\t          // User \u0111\u00e3 \u0111\u0103ng nh\u1eadp\\n40\\t          const userProfile = await getUserFromFirebaseUser(firebaseUser);\\n41\\t          const idToken = await firebaseUser.getIdToken();\\n42\\t          setUser(userProfile);\\n43\\t          setToken(idToken);\\n44\\t        } else {\\n45\\t          // User \u0111\u00e3 \u0111\u0103ng xu\u1ea5t\\n46\\t          setUser(null);\\n47\\t          setToken(null);\\n48\\t        }\\n49\\t      } catch (error) {\\n50\\t        console.error('Error in auth state change:', error);\\n51\\t        setUser(null);\\n52\\t        setToken(null);\\n53\\t      } finally {\\n54\\t        setInitializing(false);\\n55\\t      }\\n56\\t    });\\n57\\t\\n58\\t    return unsubscribe; // Cleanup subscription on unmount\\n59\\t  }, []);\\n60\\t\\n61\\t  const login = useCallback(async (email: string, password: string) => {\\n62\\t    const res = await loginApi({ email, password });\\n63\\t    // Auth state s\u1ebd \u0111\u01b0\u1ee3c c\u1eadp nh\u1eadt t\u1ef1 \u0111\u1ed9ng b\u1edfi onAuthStateChanged\\n64\\t    // Kh\u00f4ng c\u1ea7n set state \u1edf \u0111\u00e2y v\u00ec Firebase s\u1ebd t\u1ef1 \u0111\u1ed9ng trigger onAuthStateChanged\\n65\\t  }, []);\\n66\\t\\n67\\t  const register = useCallback(async (name: string, email: string, password: string) => {\\n68\\t    const res = await registerApi({ name, email, password });\\n69\\t    // Auth state s\u1ebd \u0111\u01b0\u1ee3c c\u1eadp nh\u1eadt t\u1ef1 \u0111\u1ed9ng b\u1edfi onAuthStateChanged\\n70\\t    // Kh\u00f4ng c\u1ea7n set state \u1edf \u0111\u00e2y v\u00ec Firebase s\u1ebd t\u1ef1 \u0111\u1ed9ng trigger onAuthStateChanged\\n71\\t  }, []);\\n72\\t\\n73\\t  const logout = useCallback(async () => {\\n74\\t    try {\\n75\\t      await signOut(auth);\\n76\\t      // Auth state s\u1ebd \u0111\u01b0\u1ee3c c\u1eadp nh\u1eadt t\u1ef1 \u0111\u1ed9ng b\u1edfi onAuthStateChanged\\n77\\t    } catch (error) {\\n78\\t      console.error('Error signing out:', error);\\n79\\t      throw error;\\n80\\t    }\\n81\\t  }, []);\\n82\\t\\n83\\t  const resetPassword = useCallback(async (email: string) => {\\n84\\t    await resetPasswordApi(email);\\n85\\t  }, []);\\n86\\t\\n87\\t  const value = useMemo(\\n88\\t    () => ({ user, token, initializing, login, register, logout, resetPassword }),\\n89\\t    [user, token, initializing, login, register, logout, resetPassword]\\n90\\t  );\\n91\\t\\n92\\t  return <AuthContext.Provider value={value}>{children}</AuthContext.Provider>;\\n93\\t};\\n94\\t\\n95\\texport const useAuth = (): AuthContextValue => {\\n96\\t  const ctx = useContext(AuthContext);\\n97\\t  if (!ctx) {\\n98\\t    throw new Error('useAuth must be used within an AuthProvider');\\n99\\t  }\\n100\\t  return ctx;\\n101\\t};\\n102\\t\\n103\\t\\n104\\t\"}, {'role': 'tool', 'tool_call_id': 'b30cd1f4-ae50-49cb-991b-5bbab98b0c4d', 'content': 'total 124\\ndrwxr-xr-x 1 CHINH 197609     0 Mar  3 17:45 .\\ndrwxr-xr-x 1 CHINH 197609     0 Mar 22 10:22 ..\\n-rw-r--r-- 1 CHINH 197609  2788 Mar 22 09:51 _layout.tsx\\n-rw-r--r-- 1 CHINH 197609  9891 Mar 22 10:06 community.tsx\\n-rw-r--r-- 1 CHINH 197609 58988 Mar 22 10:22 index.tsx\\n-rw-r--r-- 1 CHINH 197609 36478 Mar 22 10:05 my-field.tsx\\n-rw-r--r-- 1 CHINH 197609  5206 Mar 22 09:53 profile.tsx'}, {'role': 'assistant', 'content': '<tool_call>Read<arg_key>file_path</arg_key><arg_value>c:\\\\Users\\\\CHINH\\\\OneDrive\\\\M\u00e1y t\u00ednh\\\\AI_For_Life_CropWise\\\\CropWise\\\\services\\\\authService.ts</arg_v